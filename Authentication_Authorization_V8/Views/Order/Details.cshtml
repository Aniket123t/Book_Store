@model IEnumerable<Authentication_Authorization_V8.Models.OrderDetails>

<h3>Order Details</h3>

<table class="table">
    <thead>
        <tr>
            <th>Book</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Title</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@(item.Price* item.Quantity)</td>
            </tr>
        }
    </tbody>
</table>
